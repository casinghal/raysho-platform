# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
#
# IMPORTANT: None of these use the NEXT_PUBLIC_ prefix.
# This is intentional — they must never appear in the browser JavaScript bundle.
# All database access goes through server-side API routes only.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── ADMIN ACCESS ─────────────────────────────────────────────────────────────
# Choose any strong password — this is what you use to log into /admin
ADMIN_PASSWORD=choose-a-strong-password-here
# Choose any random 32-character string for cookie signing
ADMIN_SECRET=random-32-char-string-here

# ─── CONTENT INGESTION ────────────────────────────────────────────────────────
# YouTube Data API key — get from: console.cloud.google.com
YOUTUBE_API_KEY=your-youtube-api-key-here

# Anthropic API key — get from: console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── EMAIL (OPTIONAL — for welcome emails and weekly digest) ──────────────────
# Resend API key — get from: resend.com (free tier: 3,000 emails/day)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=hello@yourdomain.com

# ─── CRON SECURITY ────────────────────────────────────────────────────────────
# A secret token that prevents anyone else from triggering your cron jobs
# Choose any random string — copy it exactly into Vercel Cron config too
# IMPORTANT: Do NOT prefix this with NEXT_PUBLIC_ — it must never reach the browser
CRON_SECRET=random-cron-secret-here

# ─── SITE URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
